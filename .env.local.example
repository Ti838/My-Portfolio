# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── TOTP / Google Authenticator (owner resume download) ───────────────────────
# Generate with: node -e "const s=require('speakeasy');console.log(s.generateSecret({name:'Timon Portfolio'}))"
TOTP_SECRET=your_base32_totp_secret

# ── Site ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://timonbiswas.vercel.app

# ── Resume ─────────────────────────────────────────────────────────────────────
# Upload your resume PDF to Supabase Storage bucket "resume" and paste the path
RESUME_STORAGE_PATH=resume/timon-biswas-cv.pdf
